# API
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.10:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=kashy

# Firebase Admin SDK (credenciales del service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase REST API (para login/cambio de contraseña desde el backend)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_URL=https://identitytoolkit.googleapis.com/v1

# DolarAPI — URLs por país (opcional, se usan los defaults si no se definen)
DOLAR_API_URL_VE=https://ve.dolarapi.com/v1/dolares/oficial
DOLAR_API_URL_AR=https://ar.dolarapi.com/v1/dolares/oficial
DOLAR_API_URL_CL=https://cl.dolarapi.com/v1/cotizaciones/usd
DOLAR_API_URL_CO=https://co.dolarapi.com/v1/cotizaciones/usd

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# PgAdmin (docker-compose)
PGADMIN_EMAIL=admin@kashy.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
